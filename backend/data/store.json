  "faqs": [
    {
      "q": "How do I update my profile and contact information?",
      "a": "Navigate to the Settings section. Select 'Profile Information' and click Edit. Ensure you save changes to keep your phone number and email current for society alerts."
    },
    {
      "q": "What is the visitor management policy?",
      "a": "All visitors must be pre-registered via SocietyConnect. Pre-approved guests receive a QR code for seamless entry at the security gate. Walk-in visitors require host approval before access."
    },
    {
      "q": "How can I raise a technical complaint about the app?",
      "a": "Use the Complaints section and select 'Technical' as the category. Attach a screenshot if possible. Our IT team responds within 24 hours on working days."
    },
    {
      "q": "When is my maintenance bill due?",
      "a": "Monthly maintenance bills are due on the 15th of each month. You can view your current dues in the Payments section. Late fees apply after 30 days."
    },
    {
      "q": "How do I book the community hall?",
      "a": "Go to the Schedule section and click 'New Request'. Choose 'Facility Booking', select the desired date/time, and submit. Approval is typically within 48 hours."
    }
  ],
